# LLM Configuration
# Model string in LiteLLM format, e.g.:
#   openai/gpt-4o, anthropic/claude-sonnet-4-20250514, ollama/llama3
LLM_MODEL=openai/gpt-4o

# API key for the chosen provider (not required for ollama)
LLM_API_KEY=sk-...

# Interview settings
NUM_QUESTIONS=5
MAX_EVALUATOR_WORDS=50
MAX_ANSWER_LENGTH=5000
